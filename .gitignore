# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ═══════════════════════════════════════════════════════════
# Dependencies
# ═══════════════════════════════════════════════════════════
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ═══════════════════════════════════════════════════════════
# Environment & Secrets (NUNCA commitar!)
# ═══════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# ═══════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════
prisma/dev.db
prisma/dev.db-journal
*.sqlite
*.db

# ═══════════════════════════════════════════════════════════
# Build & Next.js
# ═══════════════════════════════════════════════════════════
/.next/
/out/
/build
/dist

# ═══════════════════════════════════════════════════════════
# Testing
# ═══════════════════════════════════════════════════════════
/coverage
/.nyc_output

# ═══════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ═══════════════════════════════════════════════════════════
# OS & IDE
# ═══════════════════════════════════════════════════════════
.DS_Store
.AppleDouble
.LSOverride
.vscode
.idea
*.swp
*.swo
*~
.vscode-update.log

# ═══════════════════════════════════════════════════════════
# TypeScript
# ═══════════════════════════════════════════════════════════
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo

# ═══════════════════════════════════════════════════════════
# Prisma
# ═══════════════════════════════════════════════════════════
/app/generated/prisma

# ═══════════════════════════════════════════════════════════
# Vercel
# ═══════════════════════════════════════════════════════════
.vercel

# ═══════════════════════════════════════════════════════════
# Temporary Files
# ═══════════════════════════════════════════════════════════
*.tmp
*.temp
.cache

.vercel
